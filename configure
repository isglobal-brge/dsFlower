#!/bin/sh
# dsFlower post-install configuration script
# Runs automatically during R CMD INSTALL on Unix systems.
#
# Creates Python virtual environments for each ML framework so that
# SuperNodes have all dependencies ready at runtime. This runs ONCE
# at package install time, not on every session.
#
# Self-contained: if neither Python nor uv are present, downloads uv
# (a single static binary) and uses it to install Python. No system
# dependencies required beyond a C library and curl/wget.

VENV_ROOT="${DSFLOWER_VENV_ROOT:-/var/lib/dsflower/venvs}"
DSFLOWER_HOME="$(dirname "${VENV_ROOT}")"
LOG_PREFIX="[dsFlower configure]"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

log_info() { echo "${LOG_PREFIX} $*"; }
log_warn() { echo "${LOG_PREFIX} WARNING: $*" >&2; }

check_import() { "$1" -c "import $2" 2>/dev/null; }

# ---------------------------------------------------------------------------
# Bootstrap: ensure uv + Python are available
# ---------------------------------------------------------------------------

ensure_uv() {
  # 1. Already on PATH?
  UV="$(command -v uv 2>/dev/null || true)"
  if [ -n "${UV}" ] && [ -x "${UV}" ]; then return 0; fi

  # 2. Common install locations
  for _p in "${HOME}/.local/bin/uv" "${HOME}/.cargo/bin/uv" "/usr/local/bin/uv"; do
    if [ -x "${_p}" ]; then UV="${_p}"; return 0; fi
  done

  # 3. Download uv standalone
  log_info "Downloading uv (Python package manager)..."

  # Ensure we have a download tool
  if command -v curl >/dev/null 2>&1; then
    _DL="curl -LsSf"
  elif command -v wget >/dev/null 2>&1; then
    _DL="wget -qO-"
  else
    # Try to install curl
    if command -v apt-get >/dev/null 2>&1; then
      apt-get update -qq 2>/dev/null && apt-get install -y -qq curl 2>/dev/null
      _DL="curl -LsSf"
    elif command -v apk >/dev/null 2>&1; then
      apk add --no-cache curl 2>/dev/null
      _DL="curl -LsSf"
    else
      log_warn "No curl/wget available. Cannot download uv."
      return 1
    fi
  fi

  ${_DL} https://astral.sh/uv/install.sh 2>/dev/null | sh 2>/dev/null
  UV="${HOME}/.local/bin/uv"
  if [ ! -x "${UV}" ]; then UV="$(command -v uv 2>/dev/null || true)"; fi
  if [ -n "${UV}" ] && [ -x "${UV}" ]; then
    log_info "uv installed: $(${UV} --version)"
    return 0
  fi

  log_warn "Failed to install uv."
  return 1
}

ensure_python() {
  # uv provides Python -- no system Python needed
  if [ -z "${UV}" ] || [ ! -x "${UV}" ]; then
    log_warn "No uv available. Cannot provision Python."
    return 1
  fi

  # Check if uv already manages a Python
  PYTHON="$("${UV}" python find 3.11 2>/dev/null || true)"
  if [ -n "${PYTHON}" ] && [ -x "${PYTHON}" ]; then
    log_info "Python: ${PYTHON} ($("${PYTHON}" --version 2>&1 | head -1))"
    return 0
  fi

  log_info "Installing Python 3.11 via uv..."
  "${UV}" python install 3.11 --quiet 2>&1 || true

  PYTHON="$("${UV}" python find 3.11 2>/dev/null || true)"
  if [ -n "${PYTHON}" ] && [ -x "${PYTHON}" ]; then
    log_info "Python installed: ${PYTHON} ($("${PYTHON}" --version 2>&1 | head -1))"
    return 0
  fi

  log_warn "Failed to install Python via uv."
  return 1
}

# --- Run bootstrap ---

ensure_uv || {
  log_warn "uv not available. Cannot proceed."
  log_warn "Install uv: https://docs.astral.sh/uv/"
  exit 0
}

ensure_python || {
  log_warn "No Python available. Skipping environment setup."
  exit 0
}

USE_UV=true

# Check venv root
mkdir -p "${VENV_ROOT}" 2>/dev/null || {
  log_warn "Cannot create ${VENV_ROOT}. Skipping."
  exit 0
}
mkdir -p "${DSFLOWER_HOME}/supernode_pids" 2>/dev/null || true
if id rock >/dev/null 2>&1; then
  chown rock:rock "${DSFLOWER_HOME}/supernode_pids" 2>/dev/null || true
fi
chmod 775 "${DSFLOWER_HOME}/supernode_pids" 2>/dev/null || true
log_info "Venv root: ${VENV_ROOT}"

# ---------------------------------------------------------------------------
# Installer functions
# ---------------------------------------------------------------------------

create_venv() {
  local name="$1"
  local venv_path="${VENV_ROOT}/${name}"
  if [ -d "${venv_path}" ] && [ -f "${venv_path}/.dsflower_ready" ]; then
    log_info "  ${name}: already provisioned, skipping."
    return 0
  fi
  log_info "  ${name}: creating venv..."
  rm -rf "${venv_path}"
  if [ "${USE_UV}" = true ]; then
    "${UV}" venv --python "${PYTHON}" "${venv_path}" >/dev/null 2>&1
  else
    "${PYTHON}" -m venv --system-site-packages "${venv_path}"
  fi
}

install_deps() {
  local name="$1"; shift
  local venv_path="${VENV_ROOT}/${name}"
  local venv_python="${venv_path}/bin/python"
  log_info "  ${name}: installing $*"
  if [ "${USE_UV}" = true ]; then
    "${UV}" pip install --python "${venv_python}" --quiet "$@" 2>&1 | tail -5
  else
    "${venv_path}/bin/pip" install --quiet --no-cache-dir "$@" 2>&1 | tail -5
  fi
}

mark_ready() {
  echo "$2" > "${VENV_ROOT}/$1/.dsflower_ready"
}

provision_framework() {
  local name="$1"; local check_module="$2"; shift 2; local deps="$*"
  local venv_path="${VENV_ROOT}/${name}"

  if [ -f "${venv_path}/.dsflower_ready" ]; then
    if check_import "${venv_path}/bin/python" "${check_module}" 2>/dev/null; then
      log_info "  ${name}: OK (cached)"
      return 0
    fi
    log_info "  ${name}: cached but unhealthy, rebuilding..."
  fi

  if check_import "${PYTHON}" "${check_module}" 2>/dev/null; then
    log_info "  ${name}: system Python already has ${check_module}, skipping venv."
    return 0
  fi

  create_venv "${name}" || { log_warn "  ${name}: venv failed."; return 0; }

  # shellcheck disable=SC2086
  install_deps "${name}" "flwr>=1.13.0" "numpy>=1.21.0" "pandas>=1.3.0" "pyarrow>=10.0.0" ${deps} || {
    log_warn "  ${name}: install failed."; rm -rf "${venv_path}"; return 0
  }

  if check_import "${venv_path}/bin/python" "${check_module}"; then
    dep_hash=$(echo "${deps}" | sha256sum 2>/dev/null | cut -d' ' -f1 || echo "unknown")
    mark_ready "${name}" "${dep_hash}"
    log_info "  ${name}: ready."
  else
    log_warn "  ${name}: import ${check_module} failed."; rm -rf "${venv_path}"
  fi
}

# ---------------------------------------------------------------------------
# Provision all frameworks
# ---------------------------------------------------------------------------

log_info "Provisioning Python environments for ML frameworks..."
echo ""

provision_framework "sklearn" "sklearn" \
  "scikit-learn>=1.0.0"

provision_framework "pytorch" "torch" \
  "torch>=2.0.0"

provision_framework "pytorch_vision" "torchvision" \
  "torch>=2.0.0" "torchvision>=0.15.0" "Pillow>=9.0.0"

provision_framework "xgboost" "xgboost" \
  "xgboost>=1.7.0"

# Fix Python permissions (Rock runs as non-root 'rock' user)
if [ -d "/root/.local/share/uv/python" ]; then
  chmod -R 755 /root/.local/share/uv/python/ 2>/dev/null
  chmod 755 /root /root/.local /root/.local/share /root/.local/share/uv 2>/dev/null
  log_info "Python permissions fixed for rock user"
fi

echo ""
log_info "Python environment setup complete."
log_info "Venvs stored in: ${VENV_ROOT}"

for fw in sklearn pytorch pytorch_vision xgboost; do
  venv="${VENV_ROOT}/${fw}"
  if [ -f "${venv}/.dsflower_ready" ]; then
    size=$(du -sh "${venv}" 2>/dev/null | cut -f1)
    log_info "  ${fw}: ${size}"
  fi
done

# ---------------------------------------------------------------------------
# Ensure R dependencies are installed (Rock only)
# ---------------------------------------------------------------------------

ROCK_LIB="/var/lib/rock/R/library"
if [ -d "${ROCK_LIB}" ]; then
  log_info "Checking R dependencies..."
  for pkg in arrow digest jsonlite processx rappdirs yaml; do
    Rscript --vanilla -e "
      if (!requireNamespace('${pkg}', quietly=TRUE, lib.loc='${ROCK_LIB}')) {
        cat('Installing ${pkg}...\n')
        install.packages('${pkg}', lib='${ROCK_LIB}', repos='https://cloud.r-project.org', quiet=TRUE)
      }
    " 2>/dev/null
  done
  log_info "R dependencies OK"
fi

exit 0
